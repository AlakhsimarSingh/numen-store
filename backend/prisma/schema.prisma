datasource db {
  provider = "postgresql"
}


generator client {
  provider = "prisma-client-js"
}

enum ContactStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum TokenPurpose {
  CUSTOMER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String
  status    ContactStatus @default(OPEN)
  reply     String?
  repliedAt DateTime?
  repliedBy String?
  ip        String?
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(CUSTOMER)
  authProvider AuthProvider @default(EMAIL)
  passwordHash String?
  googleId     String?      @unique
  createdAt DateTime @default(now())

  phone           String?
  gender          String?
  dob             DateTime?
  sizeTop         String?
  sizeBottom      String?
  sizeShoe        String?
  favoriteCategories String[] @default([])
  styleTags       String[] @default([])

  notifyEmailDeals   Boolean @default(true)
  notifySmsDeals     Boolean @default(false)
  notifyOrderUpdates Boolean @default(true)
  notifyNewDrops     Boolean @default(true)

  sessions        Session[]
  magicLinks      MagicLinkToken[]
  addresses       Address[]
  paymentMethods  PaymentMethod[]
  orders          Order[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  recentlyViewed  RecentlyViewed[]
  helpfulVotes    ReviewHelpfulVote[]
  contactMessages ContactMessage[]
}

model Look {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  subtitle  String?
  image     String
  active    Boolean       @default(true)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  hotspots  LookHotspot[]

  @@index([active, order])
}

model LookHotspot {
  id           String  @id @default(cuid())
  lookId       String
  look         Look    @relation(fields: [lookId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  xPercent     Float
  yPercent     Float
  defaultColor String?
  defaultSize  String?
  label        String?
  createdAt    DateTime @default(now())

  @@index([lookId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  purpose    TokenPurpose @default(CUSTOMER)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([email])
}

model Category {
  slug     String    @id
  name     String
  iconName String
  products Product[]
  sizeChart SizeChart?
}

model FlashDeal {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String   @default("Flash Deal")
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, startsAt, endsAt])
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  categorySlug   String
  category       Category @relation(fields: [categorySlug], references: [slug])
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  image          String
  images         String[] @default([])
  video          String?
  stock          Int      @default(0)
  isNew          Boolean  @default(false)
  isSpotlight    Boolean  @default(false)
  rating         Float    @default(4.5)

  colors         Json?    // ColorOption[]
  sizes          String[] @default([])
  variantStock   Json?    // VariantStockEntry[]
  regionalPrices Json?    // Partial<Record<Currency, {price, compareAtPrice}>>
  lookHotspots   LookHotspot[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flashDeals FlashDeal[]
  reviews        Review[]
  orderItems     OrderItem[]
  wishlistItems  WishlistItem[]
  recentlyViewed RecentlyViewed[]

  @@index([categorySlug])
}

model SizeChart {
  categorySlug String   @id
  category     Category @relation(fields: [categorySlug], references: [slug])
  columns      Json     // {key, label}[]
  rows         Json     // {size, values}[]
  updatedAt    DateTime @updatedAt
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zip          String
  country      String
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)

  @@index([userId])
}

model PaymentMethod {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String  // "card" | "upi"
  label     String  // masked display value only — never store real PAN/CVC
  isDefault Boolean @default(false)

  @@index([userId])
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethodId {
  CARD
  UPI
  COD
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model Order {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  subtotal       Decimal         @db.Decimal(10, 2)
  discount       Decimal         @db.Decimal(10, 2) @default(0)
  shippingFee    Decimal         @db.Decimal(10, 2) @default(0)
  tax            Decimal         @db.Decimal(10, 2) @default(0)
  codFee         Decimal         @db.Decimal(10, 2) @default(0)
  total          Decimal         @db.Decimal(10, 2)
  currency       String          @default("USD")
  status         OrderStatus     @default(PROCESSING)
  paymentMethod  PaymentMethodId

  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique

  shippingSnapshot Json          // frozen copy of address at time of order

  returnStatus  ReturnStatus?
  returnReason  String?
  returnComment String?
  returnRequestedAt DateTime?

  placedAt DateTime @default(now())
  items    OrderItem[]

  @@index([userId])
}

model PendingCheckout {
  id               String          @id @default(cuid())
  userId           String
  razorpayOrderId  String          @unique
  itemsSnapshot    Json
  shippingSnapshot Json
  promoCode        String?
  paymentMethod    PaymentMethodId
  amount           Decimal         @db.Decimal(10, 2)
  createdAt        DateTime        @default(now())

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  image     String
  price     Decimal @db.Decimal(10, 2)
  qty       Int
  color     String?
  size      String?

  @@index([orderId])
}

model Review {
  id                String   @id @default(cuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating            Int
  title             String?
  comment           String
  verifiedPurchase  Boolean  @default(false)
  helpfulCount      Int      @default(0)
  createdAt         DateTime @default(now())

  helpfulVotes ReviewHelpfulVote[]

  @@unique([productId, userId])
  @@index([productId])
}

model ReviewHelpfulVote {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, productId])
}

model PromoCode {
  code    String  @id
  percent Int
  active  Boolean @default(true)
}

model SiteSettings {
  id                     Int     @id @default(1)
  siteName               String  @default("NUMEN.")
  tagline                String  @default("Wear the Drop")
  heroHeadlineLines      String[] @default(["WEAR", "THE", "DROP."])
  heroSubtext            String  @default("")
  heroImage              String  @default("/hero-bg.jpg")
  freeShippingThreshold  Decimal @db.Decimal(10, 2) @default(75)
  shippingFee            Decimal @db.Decimal(10, 2) @default(6.99)
  taxRate                Float   @default(0.08)
  codFee                 Decimal @db.Decimal(10, 2) @default(2)
  announcementEnabled    Boolean @default(false)
  announcementText       String  @default("")
  maintenanceMode        Boolean @default(false)
}

model CurrencyRate {
  code String @id // "INR" | "EUR" | "GBP"
  rate Float
}

model AdminAllowlist {
  email     String   @id
  addedAt   DateTime @default(now())
  addedBy   String?
  note      String?
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String   // email or IP, whichever the check is keyed on
  scope      String   // "customer_login" | "customer_signup" | "admin_request_link" etc.
  createdAt  DateTime @default(now())

  @@index([identifier, scope, createdAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  email     String
  action    String
  success   Boolean  @default(true)
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}